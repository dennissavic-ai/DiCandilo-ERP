    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^3.0.0",
    "@fastify/websocket": "^10.0.1",
    "@prisma/client": "^5.14.0",
    "@types/bwip-js": "^3.2.3",
    "argon2": "^0.44.0",
    "bwip-js": "^4.8.0",
    "date-fns": "^3.6.0",
