    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.6.0",
    "jest": "^29.7.0",
    "prisma": "^5.14.0",
    "ts-jest": "^29.2.2",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
