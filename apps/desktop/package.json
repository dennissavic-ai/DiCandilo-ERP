{
  "name": "@dicandilo/desktop",
  "version": "1.0.0",
  "private": true,
  "description": "DiCandilo ERP — Desktop Wrapper",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "ELECTRON_ENV=development electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder --mac --win --linux"
  },
  "build": {
    "appId": "com.dicandilo.erp",
    "productName": "DiCandilo ERP",
    "copyright": "Copyright © 2026 DiCandilo Metal Service Center",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "src/**/*",
      "assets/**/*"
    ],
    "mac": {
      "category": "public.app-category.business",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "assets/icon.png",
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DiCandilo ERP"
    },
    "dmg": {
      "title": "DiCandilo ERP",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    }
  },
  "devDependencies": {
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1"
  }
}
